# NestList Environment Variables - Production Template

# 1. Supabase Backend Integration (Supabase project settings -> API)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 2. Application Deployment Settings
VITE_APP_URL=https://nestlist.com
CALLBACK_URL=https://nestlist.com/api/mpesa/callback

# 3. Safaricom Daraja M-Pesa Integration Settings
# Set to 'sandbox' for testing, or 'production' for live payments
MPESA_ENV=sandbox
MPESA_KEY=your_safaricom_consumer_key
MPESA_SECRET=your_safaricom_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_online_passkey

# 4. Optional Gemini AI Integration
GEMINI_API_KEY=your_gemini_api_key
